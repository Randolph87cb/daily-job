# Copy this file to .env and fill in your real key.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: choose which OpenAI text API shape to use.
# Allowed values: responses, chat
OPENAI_API_MODE=chat

# Optional: override the endpoint to match the selected API mode.
# Chat mode example:
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# Responses mode example:
# OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Optional: use a different key variable name if you prefer.
# MY_OPENAI_KEY=your_openai_api_key_here
